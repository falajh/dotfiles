[global]
    icon_path = /usr/share/icons/dracula-icons-main/16@2x/devices/:/usr/share/icons/dracula-icons-main/16/apps/:/usr/share/icons/dracula-icons-main/16/actions/:/usr/share/icons/dracula-icons-main/16/places/:/usr/share/icons/dracula-icons-main/16/panel/
    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/firefox -new-tab
	font = JetBrainsMono NF 10
	mouse_left_click = do_action, close_current
    mouse_middle_click = close_current
    mouse_right_click = close_current

[experimental]
    per_monitor_dpi = false

[urgency_low]
	background = "#282a36AE"
	foreground = "#6272a4"

[urgency_normal]
	background = "#282a36AE"
	foreground = "#bd93f9"

[urgency_critical]
    background = "#ff5555A0"
    foreground = "#f8f8f2"
    frame_color = "#ff5555"
    timeout = 0

