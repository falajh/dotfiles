return {
	"folke/noice.nvim",
	event = "VeryLazy",
	opts = {
		messages = { enabled = false }, -- enables the Noice messages UI
		popupmenu = { enabled = false }, -- enables the Noice popupmenu UI 
		notify = { enabled = false }, -- enables the Noice notify UI
		lsp = {
			hover = { enabled = false }, -- disables the Noice hover UI 
			signature = { enabled = false }, -- disables the Noice signature help UI
		},
		views = {
			cmdline_popup = {
				position = {
					row = "95%", -- This pushes it near the bottom
					col = "50%",
				},
				size = {
					width = 60,
					height = "auto",
				},
			},
		},
	},
	dependencies = {
		-- if you lazy-load any plugin below, make sure to add proper `module="..."` entries
		"MunifTanjim/nui.nvim",
	}
}
