set $zscripts /home/zaater/.config/scripts
include ~/.config/i3/keymaps
include ~/.config/i3/workspaces

font pango:Fredoka Medium 12

exec_always --no-startup-id xrdb -merge ~/.Xresources
#exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id fcitx5 -dr
exec --no-startup-id exec picom -b 
exec --no-startup-id feh --bg-fill /usr/share/backgrounds/Nighthawks_by_Edward_Hopper_1942.jpg
exec --no-startup-id $zscripts/battery-warner.sh
exec --no-startup-id xset s 600 500
exec --no-startup-id xss-lock -n /usr/share/doc/xss-lock/dim-screen.sh -- i3lock -n
exec --no-startup-id alacritty --class=scratchpad-term

set $refresh_i3status killall -SIGUSR1 i3status

set $bg #2f343f7f
bar {
	i3bar_command i3bar --transparency
	status_command i3status
	tray_padding 5
	font pango:JetBrainsMono NF Bold 10
	position top
	bindsym button5 nil
	bindsym button4 nil
	colors {
		background $bg
		statusline #f8f8f2
		separator $bg
		focused_workspace  #fffffff0 #2f343ff0 #ffffff
		inactive_workspace $bg $bg #6272a4
		urgent_workspace   $bg #2f343ff0 #ff5555
	}
}
# class                 border  bground text    indicator child_border
client.focused          #ba55d3 #ba55d3 #ffffff #bd93f9   #ba55d3
client.focused_inactive #44475A #44475A #F8F8F2 #44475A   #44475A
client.unfocused        #282A36 #282A36 #BFBFBF #282A36   #585A56
client.urgent           #44475A #FF5555 #F8F8F2 #FF5555   #FF5555
client.placeholder      #282A36 #282A36 #F8F8F2 #282A36   #282A36

popup_during_fullscreen  all
